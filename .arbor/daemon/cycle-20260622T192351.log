+from __future__ import annotations
+
+import tempfile
+import unittest
+
+from aegis_router.graph import LinkMetrics, P2PGraph
+from aegis_router.packet import Packet
+from aegis_router.solvers import EdgeLearningSolver
+
+
+def _graph() -> P2PGraph:
+    graph = P2PGraph()
+    for node in [0, 1, 2, 9]:
+        graph.add_node(node)
+    metrics = LinkMetrics(latency=0.2, bandwidth=0.8, loss=0.05, stability=0.8)
+    graph.add_edge(0, 1, metrics)
+    graph.add_edge(0, 2, metrics)
+    graph.add_edge(1, 9, metrics)
+    graph.add_edge(2, 9, metrics)
+    return graph
+
+
+class CauseSpecificRerankingTests(unittest.TestCase):
+    def test_numeric_edge_penalty_keeps_legacy_aggregate_behavior(self):
+        with tempfile.TemporaryDirectory() as td:
+            solver = EdgeLearningSolver(state_path=f"{td}/state.json", edge_penalty=2.0)
+            self.assertEqual(solver.cause_rerank_cap, 0.0)
+            self.assertEqual(solver.edge_penalty, 2.0)
+
+    def test_sybil_evidence_outweighs_recoverable_link_loss(self):
+        graph = _graph()
+        packet = Packet(packet_id=1, src=0, dst=9, created_at=0.0, ttl=10)
+        packet.node = 0
+        config = {
+            "base": 0.9,
+            "cause_rerank_cap": 4.0,
+            "delivery_weight": 0.25,
+            "link_loss_weight": 0.1,
+            "loop_weight": 0.7,
+            "ttl_weight": 0.3,
+            "sybil_weight": 1.0,
+        }
+        with tempfile.TemporaryDirectory() as td:
+            solver = EdgeLearningSolver(
+                state_path=f"{td}/state.json",
+                edge_penalty=config,
+                learned_penalty=0.0,
+                reputation_penalty=0.0,
+            )
+            for _ in range(4):
+                solver.observe_result(from_node=0, neighbor=1, delivered=False, dropped=True, reason="link_loss")
+                solver.observe_result(
+                    from_node=0,
+                    neighbor=2,
+                    delivered=False,
+                    dropped=True,
+                    touched_sybil=True,
+                    reason="sybil_drop",
+                )
+
+            self.assertEqual(solver.next_hop(graph, packet), 1)
+
+    def test_delivery_bonus_is_bounded_and_does_not_filter_actions(self):
+        graph = _graph()
+        packet = Packet(packet_id=1, src=0, dst=9, created_at=0.0, ttl=10)
+        packet.node = 0
+        with tempfile.TemporaryDirectory() as td:
+            solver = EdgeLearningSolver(
+                state_path=f"{td}/state.json",
+                edge_penalty={"cause_rerank_cap": 3.0, "delivery_weight": 10.0},
+                learned_penalty=0.0,
+                reputation_penalty=0.0,
+            )
+            for _ in range(20):
+                solver.observe_result(from_node=0, neighbor=1, delivered=True, dropped=False)
+
+            base = solver.scorer.score(
+                graph,
+                node=0,
+                neighbor=1,
+                dst=9,
+                visited=packet.visited,
+                ttl_remaining=packet.ttl,
+            )
+            reranked = solver._score(graph, packet, 1)
+            self.assertLessEqual(reranked - base, 3.0)
+            self.assertIn(solver.next_hop(graph, packet), graph.neighbors(0))
+
+
+if __name__ == "__main__":
+    unittest.main()

