+    ) -> float:
+        if not self.surprise_gated_feedback:
+            return 1.0
+        loss = 0.0 if advertised_loss is None else max(0.0, min(0.95, advertised_loss))
+        expected_weight = max(self.surprise_min_weight, 1.0 - (loss / 0.55))
+        total = score.delivered + score.drops
