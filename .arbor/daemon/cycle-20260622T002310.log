import tempfile
import unittest

from aegis_router.graph import LinkMetrics, P2PGraph
from aegis_router.packet import Packet
from aegis_router.solvers import EdgeLearningSolver


def graph_with_equal_routes() -> P2PGraph:
    graph = P2PGraph()
    metrics = LinkMetrics(latency=0.1, bandwidth=0.8, loss=0.01, stability=0.9)
    for neighbor in (1, 2, 3):
        graph.add_edge(0, neighbor, metrics)
        graph.add_edge(neighbor, 9, metrics)
    return graph


class RouteDiversificationTests(unittest.TestCase):
    def make_solver(self, state_path: str, **kwargs) -> EdgeLearningSolver:
        return EdgeLearningSolver(
            state_path=state_path,
            risk_budget=1.0,
            node_concentration_penalty=kwargs.get("node_concentration_penalty", 0.0),
            edge_concentration_penalty=kwargs.get("edge_concentration_penalty", 0.0),
            structural_suspicion_penalty=kwargs.get("structural_suspicion_penalty", 0.0),
            concentration_decay=kwargs.get("concentration_decay", 1.0),
            concentration_decay_interval=kwargs.get("concentration_decay_interval", 32),
        )

    def test_repeated_edge_is_diversified_deterministically(self):
        graph = graph_with_equal_routes()
        with tempfile.TemporaryDirectory() as td:
            solver = self.make_solver(
                f"{td}/state.json",
                edge_concentration_penalty=8.0,
            )
            choices = []
            for packet_id in range(3):
                packet = Packet(packet_id, 0, 9, 0.0, 8)
                choices.append(solver.next_hop(graph, packet))
            self.assertEqual(choices, [3, 2, 1])

    def test_destination_is_never_penalized(self):
        graph = graph_with_equal_routes()
        with tempfile.TemporaryDirectory() as td:
            solver = self.make_solver(
                f"{td}/state.json",
                node_concentration_penalty=100.0,
                edge_concentration_penalty=100.0,
            )
            solver.node_usage[9] = 1000.0
            solver.edge_usage[(1, 9)] = 1000.0
            packet = Packet(1, 1, 9, 0.0, 8)
            self.assertEqual(solver.next_hop(graph, packet), 9)

    def test_default_off_preserves_empty_usage_memory(self):
        graph = graph_with_equal_routes()
        with tempfile.TemporaryDirectory() as td:
            solver = self.make_solver(f"{td}/state.json")
            packet = Packet(1, 0, 9, 0.0, 8)
            self.assertEqual(solver.next_hop(graph, packet), 3)
            self.assertEqual(dict(solver.node_usage), {})
            self.assertEqual(dict(solver.edge_usage), {})

    def test_usage_memory_is_persistent_and_bounded(self):
        graph = graph_with_equal_routes()
        with tempfile.TemporaryDirectory() as td:
            state_path = f"{td}/state.json"
            solver = self.make_solver(
                state_path,
                node_concentration_penalty=1.0,
                concentration_decay=0.99,
                concentration_decay_interval=1,
            )
            solver.concentration_max_nodes = 2
            for packet_id in range(12):
                solver.next_hop(graph, Packet(packet_id, 0, 9, 0.0, 8))
            solver.save()
            restored = self.make_solver(
                state_path,
                node_concentration_penalty=1.0,
                concentration_decay=0.99,
                concentration_decay_interval=1,
            )
            self.assertLessEqual(len(restored.node_usage), 2)
            self.assertGreater(sum(restored.node_usage.values()), 0.0)

    def test_structural_suspicion_uses_only_local_topology(self):
        graph = graph_with_equal_routes()
        metrics = LinkMetrics(latency=0.1, bandwidth=0.8, loss=0.01, stability=0.9)
        for node in range(20, 26):
            graph.add_edge(1, node, metrics)
        with tempfile.TemporaryDirectory() as td:
            solver = self.make_solver(
                f"{td}/state.json",
                structural_suspicion_penalty=10.0,
            )
            packet = Packet(1, 0, 9, 0.0, 8)
            self.assertEqual(solver.next_hop(graph, packet), 2)


if __name__ == "__main__":
    unittest.main()

