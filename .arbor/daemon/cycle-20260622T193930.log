new file mode 100644
index 0000000..33f274b
--- /dev/null
+++ b/tests/test_confidence_gated_evidence.py
@@ -0,0 +1,148 @@
+from __future__ import annotations
+
+import json
+import tempfile
+import unittest
+
+from aegis_router.graph import LinkMetrics, P2PGraph
+from aegis_router.packet import Packet
+from aegis_router.solvers import EdgeLearningSolver, PeerScore
+
+
+class ConfidenceGatedEvidenceTests(unittest.TestCase):
+    def make_solver(self, state_path: str, **overrides: float) -> EdgeLearningSolver:
+        params = {
+            "state_path": state_path,
+            "evidence_prior_strength": 4.0,
+            "evidence_confidence_scale": 3.0,
+            "evidence_neutral_badness": 0.0,
+            "evidence_pool_weight": 0.5,
+        }
+        params.update(overrides)
+        return EdgeLearningSolver(**params)
+
+    def test_sparse_failure_is_shrunk_and_confidence_gated(self):
+        with tempfile.TemporaryDirectory() as td:
+            solver = self.make_solver(f"{td}/state.json")
+            solver.observe_result(
+                from_node=0,
+                neighbor=1,
+                delivered=False,
+                dropped=True,
+                reason="link_loss",
+            )
+
+            score = solver.edge_scores[(0, 1)]
+            self.assertLess(solver._confidence_gated_badness(score), score.badness)
+            self.assertGreater(solver._confidence_gated_badness(score), 0.0)
+
+    def test_repeated_adverse_outcomes_increase_confident_penalty(self):
+        with tempfile.TemporaryDirectory() as td:
+            solver = self.make_solver(f"{td}/state.json")
+            solver.observe_result(from_node=0, neighbor=1, delivered=False, dropped=True)
+            sparse = solver._confidence_gated_badness(solver.edge_scores[(0, 1)])
+            for _ in range(11):
+                solver.observe_result(from_node=0, neighbor=1, delivered=False, dropped=True)
+
+            repeated = solver._confidence_gated_badness(solver.edge_scores[(0, 1)])
+            self.assertGreater(repeated, sparse)
+            self.assertGreater(repeated, 0.6)
+
+    def test_clean_deliveries_reverse_early_failure_penalty(self):
+        with tempfile.TemporaryDirectory() as td:
+            solver = self.make_solver(f"{td}/state.json")
+            solver.observe_result(from_node=0, neighbor=1, delivered=False, dropped=True)
+            initial = solver._confidence_gated_badness(solver.edge_scores[(0, 1)])
+            for _ in range(12):
+                solver.observe_result(from_node=0, neighbor=1, delivered=True, dropped=False)
+
+            recovered = solver._confidence_gated_badness(solver.edge_scores[(0, 1)])
+            self.assertLess(recovered, initial)
+
+    def test_population_prior_and_state_round_trip(self):
+        with tempfile.TemporaryDirectory() as td:
+            state_path = f"{td}/state.json"
+            solver = self.make_solver(state_path)
+            solver.observe_result(
+                from_node=0,
+                neighbor=1,
+                delivered=False,
+                dropped=True,
+                touched_sybil=True,
+            )
+            solver.observe_result(from_node=0, neighbor=2, delivered=True, dropped=False)
+            solver.save()
+
+            loaded = self.make_solver(state_path)
+            self.assertEqual(loaded.edge_population_score, solver.edge_population_score)
+            self.assertEqual(
+                loaded._confidence_gated_badness(loaded.edge_scores[(0, 1)]),
+                solver._confidence_gated_badness(solver.edge_scores[(0, 1)]),
+            )
+            payload = json.loads(loaded.state_path.read_text())
+            self.assertEqual(payload["version"], 3)
+
+    def test_default_mode_keeps_legacy_badness_scoring(self):
+        graph = P2PGraph()
+        for node in [0, 1, 9]:
+            graph.add_node(node)
+        graph.add_edge(0, 1, LinkMetrics(latency=0.2, bandwidth=0.8, loss=0.1, stability=0.7))
+        graph.add_edge(1, 9, LinkMetrics(latency=0.2, bandwidth=0.8, loss=0.1, stability=0.7))
+        packet = Packet(packet_id=1, src=0, dst=9, created_at=0.0, ttl=10)
+
+        with tempfile.TemporaryDirectory() as td:
+            solver = EdgeLearningSolver(
+                state_path=f"{td}/state.json",
+                learned_penalty=2.0,
+                edge_penalty=3.0,
+            )
+            solver.peer_scores[1] = PeerScore(delivered=1, drops=1)
+            solver.edge_scores[(0, 1)] = PeerScore(delivered=3, drops=1)
+
+            base = solver.scorer.score(
+                graph,
+                node=0,
+                neighbor=1,
+                dst=9,
+                visited=packet.visited,
+                ttl_remaining=packet.ttl,
+            )
+            expected = base - (2.0 * 0.5) - (3.0 * 0.25)
+            self.assertEqual(solver._score(graph, packet, 1), expected)
+
+    def test_opt_in_mode_keeps_peer_penalty_legacy_by_default(self):
+        graph = P2PGraph()
+        for node in [0, 1, 9]:
+            graph.add_node(node)
+        graph.add_edge(0, 1, LinkMetrics(latency=0.2, bandwidth=0.8, loss=0.1, stability=0.7))
+        graph.add_edge(1, 9, LinkMetrics(latency=0.2, bandwidth=0.8, loss=0.1, stability=0.7))
+        packet = Packet(packet_id=1, src=0, dst=9, created_at=0.0, ttl=10)
+
+        with tempfile.TemporaryDirectory() as td:
+            solver = self.make_solver(
+                f"{td}/state.json",
+                learned_penalty=2.0,
+                edge_penalty=3.0,
+            )
+            solver.peer_scores[1] = PeerScore(delivered=1, drops=1)
+            solver.edge_scores[(0, 1)] = PeerScore(delivered=3, drops=1)
+            solver.edge_population_score = PeerScore(delivered=3, drops=1)
+
+            base = solver.scorer.score(
+                graph,
+                node=0,
+                neighbor=1,
+                dst=9,
+                visited=packet.visited,
+                ttl_remaining=packet.ttl,
+            )
+            expected = (
+                base
+                - (2.0 * 0.5)
+                - (3.0 * solver._confidence_gated_badness(solver.edge_scores[(0, 1)]))
+            )
+            self.assertEqual(solver._score(graph, packet, 1), expected)
+
+
+if __name__ == "__main__":
+    unittest.main()

