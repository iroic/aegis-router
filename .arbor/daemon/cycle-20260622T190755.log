+    def next_hop(self, graph: P2PGraph, packet: Packet) -> NodeId | None:
+        """Apply a control-barrier filter only when a safe action is available.
+
+        The normal risk-budget candidate set and ranking remain untouched unless
+        at least one action has destination progress, queue headroom (advertised
+        bandwidth), bounded projected loss, and learned risk below the barrier.
+        This prevents security pressure from deleting the last delivery-capable
+        action.
+        """
+        assert packet.node is not None
+        candidates = self._risk_budget_candidates(graph, packet)
+        if not candidates:
+            return None
+        if self.viability_shield_enabled:
+            safe = [nb for nb in candidates if self._is_viable_alternative(graph, packet, nb)]
+            if safe:
+                shielded = [nb for nb in candidates if self._learned_risk(packet.node, nb) < self.viability_risk_threshold]
+                if shielded:
+                    candidates = shielded
+        return max(candidates, key=lambda nb: self._score(graph, packet, nb))
+
+    def _learned_risk(self, node: NodeId, neighbor: NodeId) -> float:
+        # The barrier is local to this decision boundary. Peer-wide reputation
+        # remains in the baseline ranker, while the hard filter uses only the
+        # directional edge evidence so one bad ingress does not ban a peer
+        # everywhere.
+        return self.edge_scores[(node, neighbor)].badness
+
+    def _is_viable_alternative(self, graph: P2PGraph, packet: Packet, neighbor: NodeId) -> bool:
+        assert packet.node is not None
+        metrics = graph.metrics(packet.node, neighbor)
+        projected_loss = 1.0 - ((1.0 - packet.loss_risk) * (1.0 - metrics.loss))
+        progress = _destination_progress(graph, packet.node, neighbor, packet.dst)
+        return (
+            neighbor not in packet.visited
+            and (neighbor == packet.dst or progress >= self.viability_min_progress)
+            and metrics.bandwidth >= self.viability_min_bandwidth
+            and projected_loss <= self.viability_max_projected_loss
+            and self._learned_risk(packet.node, neighbor) < self.viability_risk_threshold
+        )
+
+
+def _destination_progress(graph: P2PGraph, node: NodeId, neighbor: NodeId, dst: NodeId) -> float:
+    """Match the scorer's anonymous ring-distance progress signal."""
+    size = max(1, len(graph.adj))
+    before_delta = abs(dst - node)
+    after_delta = abs(dst - neighbor)
+    before = min(before_delta, size - before_delta)
+    after = min(after_delta, size - after_delta)
+    if before == 0:
+        return 1.0
+    return (before - after) / before
+
 
