from __future__ import annotations

import unittest

from aegis_router.graph import LinkMetrics, P2PGraph
from aegis_router.packet import Packet
from aegis_router.solvers import EdgeLearningSolver, PeerScore


class ViabilityShieldTests(unittest.TestCase):
    def setUp(self) -> None:
        self.graph = P2PGraph()
        for node in range(11):
            self.graph.add_node(node)
        self.fast_risky = LinkMetrics(latency=0.01, bandwidth=1.0, loss=0.01, stability=1.0)
        self.safe_progress = LinkMetrics(latency=0.20, bandwidth=0.8, loss=0.02, stability=0.9)
        self.graph.add_edge(0, 9, self.fast_risky)
        self.graph.add_edge(0, 1, self.safe_progress)

    def solver(self, **kwargs) -> EdgeLearningSolver:
        return EdgeLearningSolver(
            state_path="/tmp/aegis-viability-shield-test-state.json",
            learned_penalty=0.0,
            edge_penalty=0.0,
            viability_risk_threshold=0.5,
            **kwargs,
        )

    def packet(self) -> Packet:
        return Packet(packet_id=1, src=0, dst=5, created_at=0.0, ttl=8)

    def test_filters_high_risk_neighbor_when_viable_progress_action_exists(self):
        solver = self.solver()
        solver.edge_scores[(0, 9)] = PeerScore(drops=1)

        self.assertEqual(solver.next_hop(self.graph, self.packet()), 1)

    def test_preserves_baseline_ranking_when_no_safe_alternative_exists(self):
        solver = self.solver(viability_min_bandwidth=0.95)
        solver.edge_scores[(0, 9)] = PeerScore(drops=1)

        self.assertEqual(solver.next_hop(self.graph, self.packet()), 9)

    def test_can_be_disabled_without_changing_legacy_selection(self):
        solver = self.solver(viability_shield_enabled=False)
        solver.edge_scores[(0, 9)] = PeerScore(drops=1)

        self.assertEqual(solver.next_hop(self.graph, self.packet()), 9)


if __name__ == "__main__":
    unittest.main()

